{
  "name": "@thejaredwilcurt/csslop",
  "main": "index.js",
  "type": "module",
  "version": "0.0.7",
  "description": "Experimental CSS minification",
  "scripts": {
    "prestart": "node ./scripts/prestart.js",
    "start": "vite",
    "prebuild": "node ./scripts/prebuild.js",
    "build": "vite build",
    "postbuild": "node ./scripts/postbuild.js",
    "copy": "node ./scripts/copyTests.js",
    "test": "node ./tests/index.test.js",
    "real": "node ./tests/realworld.test.js",
    "lint": "eslint *.js scripts src tests --fix",
    "bump": "npx --yes -- @jsdevtools/version-bump-prompt && npm i",
    "publish": "npm publish --access=public"
  },
  "dependencies": {
    "@csstools/css-calc": "^3.2.1",
    "@node-projects/css-parser": "^5.2.0"
  },
  "devDependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/view": "^6.43.2",
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "codemirror": "^6.0.2",
    "css-minify-tests": "github:keithamus/css-minify-tests",
    "eslint": "^10.5.0",
    "eslint-config-tjw-base": "^5.0.0",
    "eslint-config-tjw-import-x": "^1.0.1",
    "eslint-config-tjw-jsdoc": "^2.0.1",
    "eslint-plugin-import-x": "^4.17.0",
    "eslint-plugin-jsdoc": "^63.0.7",
    "fflate": "^0.8.3",
    "globals": "^17.7.0",
    "real-world-css-libraries": "^1.0.5",
    "vite": "^8.1.0"
  },
  "author": "The Jared Wilcurt",
  "homepage": "https://github.com/TheJaredWilcurt/csslop#readme",
  "bugs": {
    "url": "https://github.com/TheJaredWilcurt/csslop/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TheJaredWilcurt/csslop.git"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "26.1.0"
    },
    "packageManager": {
      "name": "npm",
      "version": "11.13.0"
    }
  }
}
